Package: mlr3learners.gpytorch
Title: GPyTorch Learner for mlr3
Version: 0.1.0
Authors@R: 
    person("Khalifa", "Seck", email = "seckhalifaa@gmail.com", 
           role = c("aut", "cre"))
Description: Provides a Gaussian Process regression learner for mlr3 using 
    GPyTorch via reticulate. Supports both CPU and GPU acceleration through 
    PyTorch backend. Implements RBF and Matern kernels with automatic feature 
    normalization.
License: MIT + file LICENSE
Depends:
    R (>= 3.6.0),
    mlr3 (>= 0.20.0)
Imports:
    R6,
    reticulate,
    checkmate,
    mlr3misc,
    paradox
Suggests:
    testthat (>= 3.0.0),
    knitr,
    rmarkdown,
    pkgdown
SystemRequirements: Python (>= 3.7), torch, gpytorch
Encoding: UTF-8
RoxygenNote: 7.3.3
Roxygen: list(markdown = TRUE)
VignetteBuilder: knitr
URL: https://github.com/KhalifaSeck/mlr3learners.gpytorch, 
    https://mlr3learners-gpytorch.netlify.app
BugReports: https://github.com/KhalifaSeck/mlr3learners.gpytorch/issues

